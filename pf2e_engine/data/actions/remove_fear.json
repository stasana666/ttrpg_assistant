{
    "type": "pf2e_action",
    "name": "remove_fear",
    "pf2e_action": {
        "name": "remove_fear",
        "resources": [
            {
                "name": "action",
                "count": 1
            }
        ],
        "pipeline": [
            {
                "name": "all_creatures",
                "type": "function_call",
                "input": {
                    "expression": "creatures()"
                },
                "function": "let",
                "output": ["all_creatures"]
            },
            {
                "name": "in_range",
                "type": "function_call",
                "input": {
                    "list": "$all_creatures",
                    "predicate": "has_line_of_effect($self, $item) && distance($self, $item) <= 6"
                },
                "function": "filter",
                "output": ["targets"]
            },
            {
                "name": "choose_target",
                "type": "function_call",
                "input": {
                    "list": "$targets"
                },
                "function": "choose_from_list",
                "output": ["target"]
            },
            {
                "name": "clear_frightened",
                "type": "function_call",
                "input": {
                    "target": "$target",
                    "condition": "Frightened"
                },
                "function": "remove_condition",
                "output": ["void"]
            },
            {
                "name": "finish",
                "type": "terminate"
            }
        ]
    }
}
