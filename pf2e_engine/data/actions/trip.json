{
    "type": "pf2e_action",
    "name": "trip",
    "pf2e_action": {
        "name": "trip",
        "resources": [
            {
                "name": "action",
                "count": 1
            }
        ],
        "pipeline": [
            {
                "name": "all_creatures",
                "type": "function_call",
                "input": {
                    "expression": "creatures()"
                },
                "function": "let",
                "output": ["all_creatures"]
            },
            {
                "name": "adjacent",
                "type": "function_call",
                "input": {
                    "list": "$all_creatures",
                    "predicate": "has_line_of_effect($self, $item) && distance($self, $item) <= 1"
                },
                "function": "filter",
                "output": ["targets"]
            },
            {
                "name": "choose_target",
                "type": "function_call",
                "input": {
                    "list": "$targets"
                },
                "function": "choose_from_list",
                "output": ["target"]
            },
            {
                "name": "calculate_DC",
                "type": "function_call",
                "input": {
                    "creature": "$target",
                    "type": "savethrow",
                    "savethrow": "Reflex"
                },
                "function": "calculate_DC",
                "output": ["Reflex_DC"]
            },
            {
                "name": "roll_trip",
                "type": "function_call",
                "input": {
                    "attacker": "$self",
                    "DC": "$Reflex_DC",
                    "type": "skill",
                    "skill": "Athletics",
                    "applies_multiple_attack_penalty": 1
                },
                "function": "roll_against_DC",
                "output": ["trip_result"]
            },
            {
                "name": "increase_map",
                "type": "function_call",
                "input": {
                    "attacker": "$self",
                    "condition": "MultipleAttackPenalty"
                },
                "function": "add_condition",
                "output": ["void"]
            },
            {
                "name": "switch_result",
                "type": "switch",
                "input": {
                    "value": "$trip_result"
                },
                "next_table": {
                    "critical_failure": "self_prone",
                    "failure": "finish",
                    "success": "target_prone",
                    "critical_success": "crit_damage_roll"
                }
            },
            {
                "name": "crit_damage_roll",
                "next": "crit_damage_deal",
                "type": "function_call",
                "input": {
                    "dice": "1d6",
                    "damage_type": "Bludgeoning"
                },
                "function": "flat_damage_roll",
                "output": ["damage"]
            },
            {
                "name": "crit_damage_deal",
                "next": "target_prone",
                "type": "function_call",
                "input": {
                    "damage": "$damage",
                    "target": "$target"
                },
                "function": "deal_damage",
                "output": ["void"]
            },
            {
                "name": "target_prone",
                "next": "finish",
                "type": "function_call",
                "input": {
                    "target": "$target",
                    "condition": "Prone",
                    "value": 1
                },
                "function": "add_condition",
                "output": ["void"]
            },
            {
                "name": "self_prone",
                "next": "finish",
                "type": "function_call",
                "input": {
                    "target": "$self",
                    "condition": "Prone",
                    "value": 1
                },
                "function": "add_condition",
                "output": ["void"]
            },
            {
                "name": "finish",
                "type": "terminate"
            }
        ]
    }
}
