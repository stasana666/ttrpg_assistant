{
    "type": "pf2e_action",
    "name": "attack_with_weapon",
    "pf2e_action": {
        "name": "attack_with_weapon",
        "resources": [
            {
                "name": "action",
                "count": 1
            }
        ],
        "pipeline": [
            {
                "name": "all_creatures",
                "type": "function_call",
                "input": {
                    "expression": "creatures()"
                },
                "function": "let",
                "output": ["all_creatures"]
            },
            {
                "name": "visible_creatures",
                "type": "function_call",
                "input": {
                    "list": "$all_creatures",
                    "predicate": "has_line_of_effect($self, $item)"
                },
                "function": "filter",
                "output": ["visible_creatures"]
            },
            {
                "name": "distances",
                "type": "function_call",
                "input": {
                    "list": "$visible_creatures",
                    "expression": "distance($self, $item)"
                },
                "function": "map",
                "output": ["distances"]
            },
            {
                "name": "min_distance",
                "type": "function_call",
                "input": {
                    "list": "$distances",
                    "expression": "min($acc, $item)"
                },
                "function": "foldl",
                "output": ["min_distance"]
            },
            {
                "name": "weapons",
                "type": "function_call",
                "input": {
                    "expression": "$self.weapons"
                },
                "function": "let",
                "output": ["weapons"]
            },
            {
                "name": "reachable_weapons",
                "type": "function_call",
                "input": {
                    "list": "$weapons",
                    "predicate": "$item.reach >= $min_distance"
                },
                "function": "filter",
                "output": ["reachable_weapons"]
            },
            {
                "name": "choose_weapon",
                "type": "function_call",
                "input": {
                    "list": "$reachable_weapons"
                },
                "function": "choose_from_list",
                "output": ["weapon"]
            },
            {
                "name": "valid_targets",
                "type": "function_call",
                "input": {
                    "list": "$visible_creatures",
                    "predicate": "distance($self, $item) <= $weapon.reach"
                },
                "function": "filter",
                "output": ["valid_targets"]
            },
            {
                "name": "choose_target",
                "type": "function_call",
                "input": {
                    "list": "$valid_targets"
                },
                "function": "choose_from_list",
                "output": ["target"]
            },
            {
                "name": "calculate_AC",
                "type": "function_call",
                "input": {
                    "creature": "$target",
                    "attacker": "$self",
                    "type": "armor_class"
                },
                "function": "calculate_DC",
                "output": [
                    "armor_class"
                ]
            },
            {
                "name": "roll_attack",
                "type": "function_call",
                "input": {
                    "attacker": "$self",
                    "DC": "$armor_class",
                    "type": "weapon_attack",
                    "weapon": "$weapon",
                    "applies_multiple_attack_penalty": 1
                },
                "function": "roll_against_DC",
                "output": [
                    "success_level"
                ]
            },
            {
                "name": "multiple_attack_penalty",
                "type": "function_call",
                "input": {
                    "attacker": "$self",
                    "condition": "MultipleAttackPenalty",
                    "weapon": "$weapon"
                },
                "function": "add_condition",
                "output": [
                    "void"
                ]
            },
            {
                "name": "attack_result",
                "type": "switch",
                "input": {
                    "value": "$success_level"
                },
                "next_table": {
                    "critical_failure": "finish",
                    "failure": "finish",
                    "success": "success",
                    "critical_success": "critical_success"
                }
            },
            {
                "name": "success",
                "next": "deal_damage",
                "type": "function_call",
                "input": {
                    "attacker": "$self",
                    "weapon": "$weapon"
                },
                "function": "weapon_damage_roll",
                "output": [
                    "damage"
                ]
            },
            {
                "name": "critical_success",
                "next": "deal_damage",
                "type": "function_call",
                "input": {
                    "attacker": "$self",
                    "weapon": "$weapon"
                },
                "function": "crit_weapon_damage_roll",
                "output": [
                    "damage"
                ]
            },
            {
                "name": "deal_damage",
                "type": "function_call",
                "function": "deal_damage",
                "input": {
                    "damage": "$damage",
                    "target": "$target"
                },
                "output": [
                    "void"
                ]
            },
            {
                "name": "finish",
                "type": "terminate"
            }
        ]
    }
}
